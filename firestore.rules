rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.role == 'student';
      allow update: if isSignedIn() && isOwner(userId) && 
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'uid', 'email']);
    }

    // --- Students Records (Submissions) ---
    match /students/{studentId} {
      // Apply isValidId to path variables for single-doc operations
      // Do not apply to 'list' as studentId doesn't exist yet for query validation
      
      allow get: if isSignedIn() && isValidId(studentId) && 
                 (resource.data.email == request.auth.token.email || isAdmin());
      
      allow list: if isSignedIn() && (resource.data.email == request.auth.token.email || isAdmin());
      
      allow create: if isSignedIn() && 
                    isValidId(studentId) &&
                    request.resource.data.email == request.auth.token.email &&
                    request.resource.data.attendance is number &&
                    request.resource.data.attendance >= 0 && request.resource.data.attendance <= 100 &&
                    request.resource.data.name is string && request.resource.data.name.size() <= 200;
      
      allow update, delete: if isAdmin() && isValidId(studentId);
    }

    // --- Predictions History ---
    match /predictions/{predId} {
      allow read: if isSignedIn() && (resource.data.studentId == request.auth.uid || isAdmin() || 
                    exists(/databases/$(database)/documents/students/$(resource.data.studentId)) && 
                    get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.email == request.auth.token.email);
      
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.confidence > 0);
      allow update, delete: if isAdmin();
    }

    // --- Subjects Management ---
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(subjectId);
    }
  }
}
